{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend/dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://cvisionaibackend.vercel.app/api/$1"
    }
  ],
  "routes": [
    {
      "src": "\\/(.*)",
      "dest": "frontend/dist/index.html"
    }
  ]
}
